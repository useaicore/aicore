{
  "name": "aicore-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:telemetry-gateway": "npm run dev --workspace @aicore/telemetry-gateway",
    "test:telemetry-gateway": "npm test --workspace @aicore/telemetry-gateway",
    "build:telemetry-gateway": "npm run build --workspace @aicore/telemetry-gateway"
  },
  "devDependencies": {
    "@types/commander": "^2.12.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.5.0",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
